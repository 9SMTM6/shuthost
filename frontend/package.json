{
    "name": "shuthost-frontend",
    "private": true,
    "type": "module",
    "scripts": {
        "typecheck": "tsc --noEmit",
        "build": "vite build",
        "build:diagrams": "node build-diagrams.ts",
        "build:prerender": "vite-node --config vite.config.ssr.ts prerender.tsx",
        "test": "playwright test",
        "install-chromium": "playwright install chromium",
        "install-chromium-ci": "playwright install chromium --with-deps",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "fmt": "biome format --write ."
    },
    "dependencies": {
        "@solidjs/meta": "^0.29.4",
        "@solidjs/router": "^0.16.1",
        "solid-js": "^1.9.5",
        "tailwindcss": "^4.1.8",
        "typescript": "^6.0.2"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.10.2",
        "@biomejs/biome": "^2.4.10",
        "@playwright/test": "^1.43.0",
        "@tailwindcss/vite": "^4.1.8",
        "@terrastruct/d2": "^0.1.33",
        "@types/node": "25.x",
        "vite": "^8.0.1",
        "vite-node": "^6.0.0",
        "vite-plugin-solid": "^2.11.6"
    }
}
