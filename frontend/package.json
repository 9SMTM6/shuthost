{
    "name": "shuthost-frontend",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=22.18.0"
    },
    "scripts": {
        "dev": "vite",
        "typecheck": "tsc --noEmit",
        "build": "vite build",
        "build:diagrams": "node build-diagrams.ts",
        "build:prerender": "vite-node --config vite.config.ssr.ts prerender.tsx",
        "test": "playwright test",
        "install-chromium": "playwright install chromium",
        "install-chromium-ci": "playwright install chromium --with-deps",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "fmt": "biome format --write ."
    },
    "dependencies": {
        "@solidjs/meta": "^0.29.4",
        "@solidjs/router": "^0.16.1",
        "lucide-solid": "^1.8.0",
        "solid-js": "^1.9.12",
        "tailwindcss": "^4.2.4",
        "typescript": "^6.0.3"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.2",
        "@biomejs/biome": "^2.4.12",
        "@playwright/test": "^1.59.1",
        "@tailwindcss/vite": "^4.2.4",
        "@terrastruct/d2": "^0.1.33",
        "@types/node": "^25.6.0",
        "vite": "^8.0.9",
        "vite-node": "^6.0.0",
        "vite-plugin-solid": "^2.11.12"
    }
}
