{
    "name": "shuthost-frontend",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "typecheck": "tsc --noEmit",
        "build:diagrams": "tsc --noEmit build-diagrams.ts && node build-diagrams.ts",
        "test": "tsc --noEmit && playwright test",
        "install-chromium": "playwright install chromium",
        "install-chromium-ci": "playwright install chromium --with-deps",
        "generate-npm-licenses": "license-checker-rseidelsohn --json > assets/generated/npm-licenses.json",
        "generate-pages": "vite-node --config vite.ssr.config.ts generate-pages.tsx"
    },
    "dependencies": {
        "@solidjs/router": "^0.16.1",
        "solid-js": "^1.9.5",
        "tailwindcss": "^4.1.8",
        "typescript": "^6.0.2"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.10.2",
        "@mermaid-js/mermaid-cli": "^11.12.0",
        "@playwright/test": "^1.43.0",
        "@tailwindcss/vite": "^4.1.8",
        "@types/node": "25.x",
        "license-checker-rseidelsohn": "^4.4.2",
        "vite": "^8.0.1",
        "vite-node": "^6.0.0",
        "vite-plugin-solid": "^2.11.6"
    }
}
