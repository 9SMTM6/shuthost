[private]
list:
    just --list

# Run a script by name. Omit name to list available scripts.
run name="" +args="":
    #!/bin/sh
    if [ -z "{{name}}" ]; then
        echo "Available scripts:"
        ls "{{source_directory()}}"/*.sh | xargs -n1 basename | sed 's/\.sh$//'
        exit 0
    fi
    "{{source_directory()}}/{{name}}.sh" {{args}}

[group('tests')]
update_all:
    cd ../../ && . ./scripts/helpers.sh && build_gnu    
    just run systemd
    cd ../../ && . ./scripts/helpers.sh && build_musl
    just run openrc
    just run compose_and_self_extracting
